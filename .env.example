# Environment variables for docker-compose

# PostgreSQL Configuration (remote VPS or local)
PG_HOST=your-vps-host.com
PG_PORT=5432
PG_USER=infinitecrawler
PG_PASSWORD=your-secure-password-here
PG_DB=infinitecrawler

# Redis Configuration (local or remote)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# API Configuration
INFINITECRAWLER_API_HOST=0.0.0.0
INFINITECRAWLER_API_PORT=8015
INFINITECRAWLER_API_TOKEN=your-secure-api-token-here

# Pinchtab Configuration (for daemon integration)
PINCHTAB_HOST=localhost
PINCHTAB_PORT=9868
PINCHTAB_TOKEN=your-pinchtab-token-here

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
